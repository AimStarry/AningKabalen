# ── Server ─────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ────────────────────────────
MONGO_URI=mongodb://localhost:27017/aningkabalen

# ── JWT ────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ── File Upload ────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# ── CORS ───────────────────────────────
CLIENT_URL=http://localhost:4200
